# DeepSeek (replaces OpenAI + Kimi)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_TOP_P=1.0
DEEPSEEK_MAX_TOKENS=120
DEEPSEEK_TIMEOUT_SECONDS=20
DEEPSEEK_ORIGIN_ENABLED=true
DEEPSEEK_CLASSIFY_ENABLED=true
DEEPSEEK_TWEET_ENABLED=true

# Bluesky auto-posting (optional)
BLUESKY_ENABLED=false
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# Optional: set your private feed URL without hardcoding it in source files
BOOTSTRAP_SOURCE_URL=

# Outbound proxy for all source requests (OPSEC — never fetch without a proxy).
# Examples: http://user:pass@host:port  or  socks5://host:port
PROXY_URL=

# Fallback: route through the built-in Tor container
USE_TOR=false
TOR_PROXY_URL=socks5://tor:9050

# Discord webhook for critical/high threat alerts
DISCORD_WEBHOOK_URL=

# XenForo user cookie value for authenticated feeds (example: breached.st)
BREACHED_XF_USER_COOKIE=

# Admin auth (separate private dashboard)
ADMIN_AUTH_ENABLED=true
ADMIN_USERNAME=admin
# Use ADMIN_PASSWORD_HASH (scrypt$N$r$p$salt_b64$hash_b64). Plain-text passwords are NOT supported.
ADMIN_PASSWORD_HASH=
ADMIN_TOKEN_SECRET=
ADMIN_TOKEN_TTL_MINUTES=720
# Optional TOTP base32 secret. If set, /api/admin/auth/login requires totp_code
ADMIN_TOTP_SECRET=

# CORS: comma-separated list of allowed origins. "*" = all (dev only).
CORS_ALLOWED_ORIGINS=*

# Disable SSL certificate verification for HTTP fetches (INSECURE — use only in isolated envs).
INSECURE_SSL=false

# Scheduler: base interval (seconds) ± jitter. Defaults: 1200 ± 600 → 10–30 min (~3×/h)
POLL_INTERVAL=1200
POLL_JITTER=600

# OpenAI (ChatGPT API fallback for victim-origin detection)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0.1
OPENAI_TOP_P=1.0
OPENAI_MAX_TOKENS=120
OPENAI_TIMEOUT_SECONDS=20
OPENAI_ORIGIN_ENABLED=true
